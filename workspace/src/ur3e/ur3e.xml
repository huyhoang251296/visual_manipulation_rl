<mujoco model="ur3e">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <option timestep="0.001">
    <flag warmstart="enable"/>
  </option>
  
  <default>
    <default class="ur3e">
      <material specular="0.5" shininess="0.25"/>
      <joint axis="0 1 0" range="-6.28319 6.28319" armature="0.1"/>
      <general gaintype="fixed" biastype="affine" ctrlrange="-6.2831 6.2831" gainprm="1000" biasprm="0 -1000 -200" forcerange="-56 56"/>
      <default class="size2">
        <joint damping="2"/>
        <general forcerange="-56 56"/>
      </default>
      
      <default class="size1">
        <general gainprm="500" biasprm="0 -500 -100" forcerange="-28 28"/>
      </default>
      <default class="size0">
        <general gainprm="250" biasprm="0 -250 -50" forcerange="-12 12"/>
      </default>
      
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="capsule" group="3"/>
        <default class="eef_collision">
          <geom type="cylinder"/>
        </default>
      </default>
      <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
    </default>
  </default>
      
  <asset>
    <material class="ur3e"name="black" rgba="0.033 0.033 0.033 1"/>
    <material class="ur3e" name="jointgray" rgba="0.278 0.278 0.278 1"/>
    <material class="ur3e" name="linkgray" rgba="0.82 0.82 0.82 1"/>
    <material class="ur3e" name="urblue" rgba="0.49 0.678 0.8 1"/>
           
    <mesh file="base_0.obj"/>
    <mesh file="base_1.obj"/>
    <mesh file="forearm_0.obj"/>
    <mesh file="forearm_1.obj"/>
    <mesh file="forearm_2.obj"/>
    <mesh file="forearm_3.obj"/>
    <mesh file="forearm_4.obj"/>
    <mesh file="forearm_5.obj"/>
    <mesh file="forearm_6.obj"/>
    <mesh file="shoulder_0.obj"/>
    <mesh file="shoulder_1.obj"/>
    <mesh file="shoulder_2.obj"/>
    <mesh file="upperarm_0.obj"/>
    <mesh file="upperarm_1.obj"/>
    <mesh file="upperarm_2.obj"/>
    <mesh file="upperarm_3.obj"/>
    <mesh file="upperarm_4.obj"/>
    <mesh file="upperarm_5.obj"/>
    <mesh file="upperarm_6.obj"/>
    <mesh file="upperarm_7.obj"/>
    <mesh file="upperarm_8.obj"/>
    <mesh file="wrist1_0.obj"/>
    <mesh file="wrist1_1.obj"/>
    <mesh file="wrist1_2.obj"/>
    <mesh file="wrist2_0.obj"/>
    <mesh file="wrist2_1.obj"/>
    <mesh file="wrist2_2.obj"/>
    <mesh file="wrist3.obj"/>
    
    <!-- gripper mesh files -->
    <!-- <mesh class="2f85" file="base_mount.stl"/>
    <mesh class="2f85" file="base.stl"/>
    <mesh class="2f85" file="driver.stl"/>
    <mesh class="2f85" file="coupler.stl"/>
